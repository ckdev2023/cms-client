# CMS 部署环境变量模板
#
# 用法：
#   cd release
#   cp .env.example .env
#   vi .env   # 至少填 DOMAIN / POSTGRES_PASSWORD / CORS_ORIGINS / ACME_EMAIL
#
# .env 一律不要提交到 git（已在 release/.gitignore 排除）

# ===== 必填 =====

# 公网域名（必须能解析到本机，否则 Caddy 自动签 HTTPS 会失败）
DOMAIN=demo.example.com

# Let's Encrypt 联系邮箱（接收证书到期提醒，必填一个真实邮箱）
ACME_EMAIL=ops@example.com

# 数据库密码（强密码，至少 24 位，含大小写数字符号）
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# 后端 CORS 白名单（多个用逗号分隔，必须含 DOMAIN 对应的 https URL）
CORS_ORIGINS=https://demo.example.com

# ===== 可选（默认值能用） =====

POSTGRES_USER=cms
POSTGRES_DB=cms

# 监听端口（一般不需要改；80/443 被占用时可换）
HTTP_PORT=80
HTTPS_PORT=443

# 存储方式：local（默认，挂载 release/data/storage） | s3
STORAGE_PROVIDER=local

# S3 配置（仅 STORAGE_PROVIDER=s3 时需要）
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=

# 翻译服务（passthrough = 不翻译，原样返回）
TRANSLATION_PROVIDER=passthrough
TRANSLATION_API_KEY=

# Worker 任务锁超时（秒），默认 600
WORKER_LOCK_TTL_SECONDS=600

# ===== 可选：日志栈（启用 docker-compose.logs.yml overlay 时才需要）=====

# Grafana 管理员账号密码。启用 logs overlay 时必填。
GRAFANA_ADMIN_USER=admin
# 随机 24+ 位强密码；仅本机 / SSH tunnel 访问也要改默认值
GRAFANA_ADMIN_PASSWORD=
# Grafana 监听端口（默认仅 127.0.0.1:3000，远程访问请走 ssh tunnel）
GRAFANA_PORT=3000
# Grafana 反代根 URL（如果通过 caddy 子路径暴露，例如 https://demo.example.com/grafana）
GRAFANA_ROOT_URL=http://127.0.0.1:3000

# 日志归档保留天数（log-export.sh 用），默认 30
LOG_RETENTION_DAYS=30
