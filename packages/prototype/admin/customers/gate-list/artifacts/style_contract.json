{
  "style_mode": "prototype_css",
  "source_classes": [
    "antialiased",
    "app-shell",
    "apple-card",
    "apple-input",
    "apple-label",
    "apple-table",
    "brand",
    "brand-title",
    "btn-pill",
    "btn-primary",
    "btn-secondary",
    "chip",
    "icon-btn",
    "link-apple",
    "mobile-nav",
    "mobile-nav-backdrop",
    "mobile-nav-panel",
    "modal-backdrop",
    "apple-modal",
    "nav-group-title",
    "nav-item",
    "row-quick-action",
    "search",
    "search-input",
    "segment-btn",
    "segmented-control",
    "side-nav",
    "side-nav-inner",
    "skip-link",
    "summary-card",
    "summary-card--info",
    "summary-card--neutral",
    "summary-card--primary",
    "summary-card--warning",
    "summary-card__dot",
    "summary-card__hint",
    "summary-card__label",
    "summary-card__value",
    "table-actions",
    "table-checkbox",
    "topbar",
    "topbar-inner"
  ],
  "mapping_rules": [
    { "prototype": "apple-card", "production": "shared/ui card component" },
    { "prototype": "apple-input", "production": "shared/ui form input" },
    { "prototype": "apple-label", "production": "shared/ui form label" },
    { "prototype": "apple-table", "production": "shared/ui table component" },
    { "prototype": "btn-primary", "production": "shared/ui button variant=primary" },
    { "prototype": "btn-secondary", "production": "shared/ui button variant=secondary" },
    { "prototype": "btn-pill", "production": "shared/ui button variant=pill" },
    { "prototype": "chip", "production": "shared/ui chip/badge component" },
    { "prototype": "segmented-control + segment-btn", "production": "shared/ui segmented control" },
    { "prototype": "modal-backdrop + apple-modal", "production": "shared/ui modal/dialog" },
    { "prototype": "search-input", "production": "shared/ui search input" },
    { "prototype": "summary-card", "production": "customers/components SummaryCard" },
    { "prototype": "table-checkbox", "production": "shared/ui checkbox" },
    { "prototype": "table-actions + row-quick-action", "production": "shared/ui table action buttons" }
  ],
  "tokens_to_resolve": ["spacing", "color", "typography", "radius", "shadow"]
}
