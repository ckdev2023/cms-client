{
  "style_mode": "prototype_css",
  "source_files": [
    "packages/prototype/admin/leads-message/styles/detail.css",
    "packages/prototype/admin/shared/styles/tokens.css",
    "packages/prototype/admin/shared/styles/shell.css",
    "packages/prototype/admin/shared/styles/components.css"
  ],
  "source_classes": [
    "antialiased",
    "app-shell",
    "apple-card",
    "apple-input",
    "apple-label",
    "apple-modal",
    "brand",
    "brand-title",
    "btn-highlight",
    "btn-pill",
    "btn-primary",
    "btn-secondary",
    "channel-chip",
    "chip",
    "conversion-card",
    "conversion-card-icon",
    "dedup-panel",
    "detail-readonly",
    "detail-tab",
    "detail-tabs",
    "info-label",
    "info-value",
    "is-active",
    "is-empty",
    "is-visible",
    "lead-badge",
    "lead-badge-following",
    "lead-badge-lost",
    "lead-badge-new",
    "lead-badge-pending_sign",
    "lead-badge-signed",
    "link-apple",
    "log-type-chip",
    "mobile-nav",
    "mobile-nav-backdrop",
    "mobile-nav-panel",
    "modal-backdrop",
    "nav-group-title",
    "nav-item",
    "page-shell",
    "readonly-banner",
    "search",
    "segment-btn",
    "segmented-control",
    "side-nav",
    "side-nav-inner",
    "skip-link",
    "tab-panel",
    "timeline",
    "timeline-dot",
    "timeline-item",
    "topbar",
    "topbar-avatar",
    "topbar-inner",
    "warning-banner"
  ],
  "mapping_rules": [
    { "from": ".lead-badge-*", "to": "LeadStatusBadge variant prop", "scope": "features/lead" },
    { "from": ".detail-tab / .tab-panel / .is-active", "to": "LeadDetailTabs + TabPanel state", "scope": "features/lead" },
    { "from": ".readonly-banner / .is-visible", "to": "ReadonlyBanner isVisible prop", "scope": "shared/ui" },
    { "from": ".warning-banner / .is-visible", "to": "WarningBanner isVisible prop", "scope": "shared/ui" },
    { "from": ".detail-readonly", "to": "LeadDetailPage isReadonly prop → pointer-events:none + opacity", "scope": "features/lead" },
    { "from": ".info-label / .info-value", "to": "InfoField label + value typography", "scope": "shared/ui" },
    { "from": ".timeline / .timeline-item / .timeline-dot", "to": "Timeline + TimelineItem base layout", "scope": "shared/ui" },
    { "from": ".channel-chip + color variants", "to": "ChannelChip channel prop", "scope": "shared/ui" },
    { "from": ".log-type-chip + color variants", "to": "LogTypeChip type prop", "scope": "shared/ui" },
    { "from": ".conversion-card / .conversion-card-icon", "to": "ConversionCard layout", "scope": "features/lead" },
    { "from": ".dedup-panel", "to": "DedupPanel warning state styling", "scope": "features/lead" },
    { "from": ".segment-btn / .active", "to": "SegmentedControl option state", "scope": "shared/ui" },
    { "from": ".btn-highlight / pulse-highlight", "to": "Button highlight variant (signed状态下转化按钮)", "scope": "shared/ui" },
    { "from": ".modal-backdrop / .apple-modal", "to": "Modal base (shared)", "scope": "shared/ui", "notes": "5 modal workflows: convert-customer / convert-case / dedup-confirm / change-status / edit-info" },
    { "from": ".apple-card / .apple-input / .apple-label", "to": "Card / Input / Label (shared components)", "scope": "shared/ui" },
    { "from": ".page-shell", "to": "max-width: 1220px content wrapper", "scope": "shared/ui" }
  ],
  "tokens_to_resolve": [
    "spacing: gap-2/3/4, p-4/5/6, m-2/3/4/5/6, grid gap-x-8 gap-y-5",
    "color: --bg, --surface, --surface-2, --border, --text, --muted, --muted-2, --primary; lead-badge 5 variant colors; channel-chip 4 colors; log-type-chip 3 colors; warning amber/yellow; dedup panel amber border+bg",
    "typography: 32px/800 title, 16px/800 card h2, 14px/600 info value, 13px/700 body, 12px/800 label, 11px/800 chip, 10px/700 avatar; Plus Jakarta Sans + negative tracking",
    "radius: --radius (14px cards), 9999px badges/chips, 10px conversion-card-icon, 6px log-type-chip, rounded-2xl toast",
    "shadow: --shadow (card shadow), 0 0 0 1px timeline-dot box-shadow"
  ]
}
